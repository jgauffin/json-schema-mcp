{
  "title": "Order Schema",
  "description": "Schema for e-commerce orders",
  "$defs": {
    "Address": {
      "title": "Postal Address",
      "type": "object",
      "properties": {
        "street": { "type": "string" },
        "city": { "type": "string" },
        "zip": { "type": "string" }
      },
      "required": ["street", "city", "zip"]
    },
    "LineItem": {
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "quantity": { "type": "integer", "minimum": 1 },
        "price": { "type": "number" }
      },
      "required": ["productId", "quantity", "price"]
    },
    "Order": {
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "shippingAddress": { "$ref": "#/$defs/Address" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/LineItem" }
        }
      },
      "required": ["orderId", "shippingAddress", "items"]
    }
  }
}
